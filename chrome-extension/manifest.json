{
  "manifest_version": 3,
  "name": "Job Tracker — LinkedIn Saver",
  "version": "1.0.0",
  "description": "Save LinkedIn jobs to your local Job Tracker app",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["config.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Tracker"
  }
}
