# ═══════════════════════════════════════════════════════════════
#  LLM PROVIDER — pick ONE block and fill in its key/model
# ═══════════════════════════════════════════════════════════════
#
#  MODEL_TYPE:  cloud | local
#  LLM_PROVIDER: gemini | anthropic | openai | ollama
#
# ── FREE: Google Gemini (recommended, no credit card required) ─
MODEL_TYPE=cloud
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
GEMINI_API_KEY=AIzaSy...          # get free key at aistudio.google.com
#
# ── PAID: Anthropic Claude ─────────────────────────────────────
# MODEL_TYPE=cloud
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...
#
# ── PAID: OpenAI ───────────────────────────────────────────────
# MODEL_TYPE=cloud
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
#
# ── FREE LOCAL: Ollama (must have Ollama installed & running) ──
# MODEL_TYPE=local
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2           # or mistral, phi3, gemma2, etc.
# OLLAMA_BASE_URL=http://localhost:11434
#
# ═══════════════════════════════════════════════════════════════
#  OPTIONAL — only uncomment to override defaults
# ═══════════════════════════════════════════════════════════════

# ── LLM tuning ───────────────────────────────────────────────
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=4096

# ── API Server ────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
# API_RELOAD=false

# ── CORS (comma-separated allowed frontend origins) ───────────
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Person ────────────────────────────────────────────────────
# PERSON_NAME=Your Name
# PERSON_EMAIL=you@email.com
# PERSON_PHONE=+1 555 000 0000
# PERSON_ADDRESS=City, State, Country

# ── CV template (auto-set on CV upload) ──────────────────────
# CV_TEMPLATE=professional

# ── Google Sheets (optional integration) ─────────────────────
# GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json
# GOOGLE_SHEETS_SPREADSHEET_ID=

# ── LinkedIn scraping (optional) ─────────────────────────────
# LINKEDIN_LI_AT_COOKIE=
